{{!
    @template local_xpstore/analytics_page

    Example context (json):
    {
        "courseid": 1,
        "has_data": true,
        "str_analytics": "Analytics",
        "str_analyticssubtitle": "Metrics",
        "str_toprewardsbypurchases": "Top",
        "str_toprewardsbyxp": "Top",
        "str_totalpurchases": "Total",
        "str_totalxp": "Total",
        "str_totalstudents": "Total",
        "str_engagementrate": "Rate",
        "str_viewaudit": "View",
        "str_nopurchases": "None",
        "reporturl": "#",
        "storeurl": "#",
        "str_tiendaxp": "Store",
        "totalpurchases": 100,
        "totalxp": "5,000",
        "engagedstudents": 50,
        "engagementrate": 20,
        "chart_purchases_html": "...",
        "chart_xp_html": "..."
    }
}}
<div class="local_xpstore-container report-wrapper">
    {{> local_xpstore/navigation_tabs }}

    <div class="form-box mb-4">
    <div class="header-container" style="flex-wrap: wrap; margin-top: 0;">
        <div class="header-title">
            <h5 class="mb-1 font-weight-bold">{{str_analytics}}</h5>
            <p style="color: #777; font-weight: 600; font-size: 0.95rem;">{{str_analyticssubtitle}}</p>
        </div>
    </div>

    {{#has_data}}
    <!-- Stats Cards -->
    <div style="display: flex; gap: 20px; margin-bottom: 30px; flex-wrap: wrap;">
        
        <div style="flex: 1; min-width: 200px; padding: 25px 20px; border-radius: 16px; box-shadow: 0 10px 20px rgba(0, 97, 255, 0.15); text-align: center; background: linear-gradient(135deg, #0061ff 0%, #60efff 100%); color: white; position: relative; overflow: hidden;">
            <div style="font-size: 3rem; font-weight: 800; line-height: 1; text-shadow: 0 2px 5px rgba(0,0,0,0.1);">{{totalpurchases}}</div>
            <div style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; margin-top: 12px; letter-spacing: 1px; opacity: 0.9;">{{str_totalpurchases}}</div>
        </div>
        
        <div style="flex: 1; min-width: 200px; padding: 25px 20px; border-radius: 16px; box-shadow: 0 10px 20px rgba(255, 138, 0, 0.15); text-align: center; background: linear-gradient(135deg, #ff8a00 0%, #e52e71 100%); color: white; position: relative; overflow: hidden;">
            <div style="font-size: 3rem; font-weight: 800; line-height: 1; text-shadow: 0 2px 5px rgba(0,0,0,0.1);">{{totalxp}}</div>
            <div style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; margin-top: 12px; letter-spacing: 1px; opacity: 0.9;">{{str_totalxp}}</div>
        </div>

        <div style="flex: 1; min-width: 200px; padding: 25px 20px; border-radius: 16px; box-shadow: 0 10px 20px rgba(17, 153, 142, 0.15); text-align: center; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white; position: relative; overflow: hidden;">
            <div style="font-size: 3rem; font-weight: 800; line-height: 1; text-shadow: 0 2px 5px rgba(0,0,0,0.1);">{{engagedstudents}}</div>
            <div style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; margin-top: 12px; letter-spacing: 1px; opacity: 0.9;">{{str_totalstudents}}</div>
        </div>

        <div style="flex: 1; min-width: 200px; padding: 25px 20px; border-radius: 16px; box-shadow: 0 10px 20px rgba(142, 45, 226, 0.15); text-align: center; background: linear-gradient(135deg, #8E2DE2 0%, #4A00E0 100%); color: white; position: relative; overflow: hidden;">
            <div style="font-size: 3rem; font-weight: 800; line-height: 1; text-shadow: 0 2px 5px rgba(0,0,0,0.1);">{{engagementrate}}%</div>
            <div style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; margin-top: 12px; letter-spacing: 1px; opacity: 0.9;">{{str_engagementrate}}</div>
        </div>
        
    </div>

    <!-- Charts -->
    <div style="display: flex; gap: 20px; flex-wrap: wrap;">
        <div style="flex: 1 1 0; min-width: 0; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); overflow: hidden;">
            <h3 style="font-size: 1.2rem; margin-top: 0; margin-bottom: 20px; color: #333; text-align: center;">{{str_toprewardsbypurchases}}</h3>
            <div style="width: 100%; overflow-x: auto;">
                {{{chart_purchases_html}}}
            </div>
        </div>
        <div style="flex: 1 1 0; min-width: 0; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); overflow: hidden;">
            <h3 style="font-size: 1.2rem; margin-top: 0; margin-bottom: 20px; color: #333; text-align: center;">{{str_toprewardsbyxp}}</h3>
            <div style="width: 100%; overflow-x: auto;">
                {{{chart_xp_html}}}
            </div>
        </div>
    </div>
    {{/has_data}}

    {{^has_data}}
        <div class="text-center py-5 text-muted" style="margin-top: 40px; font-size: 1.1rem; background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
            <i class="fa fa-bar-chart" style="font-size: 3rem; color: #ccc; margin-bottom: 15px; display: block;"></i>
            {{str_nopurchases}}
        </div>
    {{/has_data}}
    </div>

</div>
