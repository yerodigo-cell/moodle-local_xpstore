    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var tbody = document.querySelector('.table-products tbody');
        if (tbody) {
            Sortable.create(tbody, {
                handle: '.drag-handle',
                animation: 150,
                onEnd: function (evt) {
                    var rows = tbody.querySelectorAll('tr.sortable-row');
                    var rawItems = [];
                    rows.forEach(function(row) {
                        if (row.dataset.rawitem) {
                            rawItems.push(row.dataset.rawitem);
                        }
                    });

                    var formData = new FormData();
                    formData.append('sesskey', '{{sesskey}}');
                    formData.append('action', 'reorder');
                    rawItems.forEach(function(item) {
                        formData.append('rawitems[]', item);
                    });

                    fetch('{{url}}', {
                        method: 'POST',
                        body: formData
                    }).then(function(response) {
                        return response.json();
                    }).then(function(data) {
                        if (data.success) {
                            evt.item.style.transition = 'background-color 0.5s';
                            evt.item.style.backgroundColor = '#e8f5e9';
                            setTimeout(function(){ evt.item.style.backgroundColor = ''; }, 1000);
                        }
                    });
                }
            });
        }

        var selectAll = document.getElementById('select-all-products');
        var checkboxes = document.querySelectorAll('.product-checkbox');
        var btnDeleteSelected = document.getElementById('btn-delete-selected');

        function updateDeleteBtn() {
            var anyChecked = Array.from(checkboxes).some(function(cb) { return cb.checked; });
            if(btnDeleteSelected) btnDeleteSelected.style.display = anyChecked ? 'inline-block' : 'none';
        }

        if(selectAll) {
            selectAll.addEventListener('change', function() {
                checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
                updateDeleteBtn();
            });
        }

        checkboxes.forEach(function(cb) {
            cb.addEventListener('change', function() {
                var allChecked = Array.from(checkboxes).every(function(c) { return c.checked; });
                if(selectAll) selectAll.checked = allChecked;
                updateDeleteBtn();
            });
        });
    });
    </script>
