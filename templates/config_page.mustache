{{#js}}
require(['local_xpstore/config_page'], function(mod) {
    mod.init();

    // Predefined Palettes logic (placed here to avoid requiring Grunt AMD compilation)
    var paletteBtns = document.querySelectorAll('.palette-btn');
    var colorPrimary = document.querySelector('input[name="color_primary"]');
    var colorSecondary = document.querySelector('input[name="color_secondary"]');
    var colorIcon = document.querySelector('input[name="color_icon"]');
    var colorCatIcon = document.querySelector('input[name="color_cat_icon"]');

    paletteBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
            if (colorPrimary) {
                colorPrimary.value = this.getAttribute('data-primary');
                colorPrimary.dispatchEvent(new Event('change'));
            }
            if (colorSecondary) {
                colorSecondary.value = this.getAttribute('data-secondary');
                colorSecondary.dispatchEvent(new Event('change'));
            }
            if (colorIcon) {
                colorIcon.value = this.getAttribute('data-icon');
                colorIcon.dispatchEvent(new Event('change'));
            }
            if (colorCatIcon) {
                colorCatIcon.value = this.getAttribute('data-caticon');
                colorCatIcon.dispatchEvent(new Event('change'));
            }
        });
    });
});
{{/js}}
