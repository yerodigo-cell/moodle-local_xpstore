{{!
    @template local_xpstore/report_page

    Example context (json):
    {
        "url": "https://moodle.org",
        "actionurl": "https://moodle.org",
        "cpstore": "#0056D2",
        "cbstore": "#00C9A7",
        "cistore": "#ff9800",
        "ccstore": "#ffffff",
        "cpactual": "#0056D2",
        "cbactual": "#00C9A7",
        "ciactual": "#ff9800",
        "ccactual": "#ffffff",
        "showbackbutton": true,
        "isteacher": false,
        "saldo": 100,
        "str_configtitle": "Configuration",
        "storecategories": [],
        "str_choosetype": "Choose type",
        "str_chooseactivity": "Choose activity",
        "str_widget_panel_title": "Widgets",
        "str_widget_panel_desc": "Desc",
        "str_colorconfig": "Color",
        "str_primarycolor": "Primary",
        "str_secondarycolor": "Secondary",
        "str_iconcolor": "Icon",
        "str_color_cat_icon": "Cat",
        "str_resetcolors": "Reset",
        "str_savecolors": "Save",
        "str_confirmresetcolors": "Confirm",
        "type_options": [{"value": "1", "label": "dummy"}],
        "activity_options": [{"id": 1, "name": "dummy"}],
        "category_icon_options": [{"catname": "d", "cathash": "h", "currenticon": "star", "icons": [{"value": "star", "label": "Star"}]}],
        "category_iframe_options": [{"iframecat": "a", "currenticon": "star", "catname": "Cat"}]
    }
}}
<div class="local_xpstore-container report-wrapper">
    {{> local_xpstore/navigation_tabs }}

    <div class="form-box mb-4">
    <div class="header-container" style="flex-wrap: wrap; margin-top: 0;">
        <div class="header-title">
            <h5 class="mb-1 font-weight-bold">{{str_reporttitle}}</h5>
            <p style="color: #777; font-weight: 600; font-size: 0.95rem;">{{str_reportsubtitle}}</p>
        </div>
        <div style="width: 100%; margin-top: 15px; background: #fff; padding: 12px 15px; border-radius: 10px; border: 1px solid #eaeaea; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
            <form action="report.php" method="GET" style="display: flex; gap: 10px; align-items: center; margin: 0; flex-wrap: wrap;">
                <input type="hidden" name="id" value="{{courseid}}">
                
                <div style="display: flex; align-items: center; gap: 10px; flex-grow: 1; border: 1px solid #dcdcdc; border-radius: 8px; padding: 0 12px; background: #fafafa; transition: border-color 0.2s;">
                    <i class="fa fa-user text-muted" style="font-size: 0.9rem;"></i>
                    <input type="text" name="searchuser" class="form-control border-0 shadow-none" placeholder="{{str_searchuser}}" value="{{searchuser}}" style="background: transparent; box-shadow: none; flex-grow: 1; min-width: 150px; height: 42px; outline: none; padding-left: 5px;">
                    <div style="width: 1px; height: 24px; background: #dcdcdc;"></div>
                    <i class="fa fa-tag text-muted" style="font-size: 0.9rem;"></i>
                    <input type="text" name="search" class="form-control border-0 shadow-none" placeholder="{{str_searchactivity}}" value="{{search}}" style="background: transparent; box-shadow: none; flex-grow: 1; min-width: 150px; height: 42px; outline: none; padding-left: 5px;">
                    <div style="width: 1px; height: 24px; background: #dcdcdc;"></div>
                    <i class="fa fa-search text-muted" style="font-size: 0.9rem; margin-left: 5px;"></i>
                    <input type="text" name="searchlabel" class="form-control border-0 shadow-none" placeholder="{{str_searchtype}}" value="{{searchlabel}}" style="background: transparent; box-shadow: none; flex-grow: 1; min-width: 150px; height: 42px; outline: none; padding-left: 5px;">
                </div>

                <button type="submit" class="btn btn-primary" style="border-radius: 8px; font-weight: 600; padding: 0 24px; height: 44px; display: flex; align-items: center; gap: 8px;">
                    {{str_search}}
                </button>
                
                {{#has_search}}
                <a href="report.php?id={{courseid}}" class="btn btn-light text-muted" title="{{str_clear}}" style="height: 44px; display: flex; align-items: center; justify-content: center; width: 44px; border-radius: 8px; border: 1px solid #dcdcdc; background: #fff;">
                    <i class="fa fa-times"></i>
                </a>
                {{/has_search}}
                
                <div style="margin-left: 5px;">{{{helpicon}}}</div>
            </form>
        </div>
    </div>
    {{#has_users}}
        {{#users}}
        <div class="user-card">
            <div class="card-header-user" data-userid="{{userid}}">
                <div class="u-avatar-container">
                    {{{userpichtml}}}
                </div>
                <div class="u-info">
                    <div class="u-name">
                        <a href="{{profileurl}}" onclick="event.stopPropagation();" style="color: inherit; text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'" target="_blank">
                            {{userfullname}}
                        </a>
                    </div>
                    <div class="u-email">{{useremail}}</div>
                </div>
                <div class="u-stats" style="display: flex; gap: 24px; align-items: center; margin-left: auto; margin-right: 20px;">
                    <div class="stat-item" style="font-size: 0.95rem; font-weight: 700; color: #444;">
                        {{totalcanjes}} <span style="font-weight: 600; color: #888; font-size: 0.85rem;">{{str_redemptions}}</span>
                    </div>
                    <div style="width: 1px; height: 20px; background: #eaeaea;"></div>
                    <div class="stat-item" style="font-size: 0.95rem; font-weight: 700; color: #f57c00;">
                        <i class="fa fa-star" style="font-size: 0.8rem; margin-right: 3px;"></i>{{str_totalspent}}
                    </div>
                    <div style="width: 1px; height: 20px; background: #eaeaea;"></div>
                    <div class="stat-item" style="font-size: 0.95rem; font-weight: 700; color: #2E7D32;">
                        <i class="fa fa-money" style="font-size: 0.8rem; margin-right: 3px;"></i>{{str_remainingbalance}}
                    </div>
                </div>
                <a href="{{userreseturl}}" class="btn-reset-user" onclick="event.stopPropagation(); return confirm('{{str_confirmresetuser}}');" style="color: #adb5bd; border: none; background: transparent; font-size: 1.1rem; padding: 6px 10px; border-radius: 6px; transition: all 0.2s; cursor: pointer; z-index: 2;" title="{{str_resetuser}}" onmouseover="this.style.color='#dc3545'; this.style.backgroundColor='#fff5f5';" onmouseout="this.style.color='#adb5bd'; this.style.backgroundColor='transparent';">
                    <i class="fa fa-trash"></i>
                </a>
                <i class="fa fa-chevron-down text-muted" id="icon-{{userid}}" style="margin-left: 10px;"></i>
            </div>
            
            <div class="card-body-logs" id="logs-{{userid}}">
                <div class="card-body-logs-inner">
                <table class="table-logs">
                    <thead>
                        <tr>
                            <th>{{str_activity}}</th>
                            <th>{{str_colcategory}}</th>
                            <th>{{str_type}}</th>
                            <th class="text-center">{{str_cost}}</th>
                            <th class="text-right">{{str_date}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#logs}}
                        <tr>
                            <td class="font-weight-bold" style="font-size: 0.9rem; color: #444;">
                                {{{activityhtml}}}
                                {{#customlabel}}
                                <div style="font-size: 0.75rem; color: #777; margin-top: 4px; font-weight: normal;">
                                    <i class="fa fa-tag text-muted" style="margin-right: 3px;"></i>{{customlabel}}
                                </div>
                                {{/customlabel}}
                            </td>
                            <td>
                                <span style="background: #f0f0f0; color: #555; padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: bold; white-space: nowrap;">
                                    {{categoriatexto}}
                                </span>
                            </td>
                            <td>
                                <span class="badge-tipo bg-{{tipostr}}">
                                    {{labeltipo}}
                                </span>
                            </td>
                            <td class="text-center font-weight-bold text-primary">
                                {{amount}} XP
                            </td>
                            <td class="text-right small text-muted">
                                {{date}}
                            </td>
                        </tr>
                        {{/logs}}
                    </tbody>
                </table>
                </div>
            </div>
        </div>
        {{/users}}
    {{/has_users}}
    {{^has_users}}
        <div class="text-center py-5 text-muted">
            {{str_nopurchases}}
        </div>
    {{/has_users}}
    </div>
</div>
