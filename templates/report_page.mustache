{{!
    @template local_xpstore/report_page

    Example context (json):
    {
        "url": "https://moodle.org",
        "actionurl": "https://moodle.org",
        "cpstore": "#0056D2",
        "cbstore": "#00C9A7",
        "cistore": "#ff9800",
        "ccstore": "#ffffff",
        "cpactual": "#0056D2",
        "cbactual": "#00C9A7",
        "ciactual": "#ff9800",
        "ccactual": "#ffffff",
        "showbackbutton": true,
        "isteacher": false,
        "saldo": 100,
        "str_configtitle": "Configuration",
        "storecategories": [],
        "str_choosetype": "Choose type",
        "str_chooseactivity": "Choose activity",
        "str_widget_panel_title": "Widgets",
        "str_widget_panel_desc": "Desc",
        "str_colorconfig": "Color",
        "str_primarycolor": "Primary",
        "str_secondarycolor": "Secondary",
        "str_iconcolor": "Icon",
        "str_color_cat_icon": "Cat",
        "str_resetcolors": "Reset",
        "str_savecolors": "Save",
        "str_confirmresetcolors": "Confirm",
        "type_options": [{"value": "1", "label": "dummy"}],
        "activity_options": [{"id": 1, "name": "dummy"}],
        "category_icon_options": [{"catname": "d", "cathash": "h", "currenticon": "star", "icons": [{"value": "star", "label": "Star"}]}],
        "category_iframe_options": [{"iframecat": "a", "currenticon": "star", "catname": "Cat"}]
    }
}}
<div class="local_xpstore-container report-wrapper">
    <div class="header-container">
        <div class="header-title">
            <h2>{{str_reporttitle}}</h2>
            <p>{{str_reportsubtitle}}</p>
        </div>
        <div>
            <a href="{{storeurl}}" class="btn-tienda">
                <i class="fa fa-arrow-left"></i> {{str_tiendaxp}}
            </a>
            <a href="{{reseturl}}" class="btn-reset" onclick="return confirm('{{str_confirmreset}}')">
                <i class="fa fa-trash"></i> {{str_resetcycle}}
            </a>
        </div>
    </div>

    {{#has_users}}
        {{#users}}
        <div class="user-card">
            <div class="card-header-user" data-userid="{{userid}}">
                <div class="u-avatar-container">
                    {{{userpichtml}}}
                </div>
                <div class="u-info">
                    <div class="u-name">
                        <a href="{{profileurl}}" onclick="event.stopPropagation();" style="color: inherit; text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'" target="_blank">
                            {{userfullname}}
                        </a>
                    </div>
                    <div class="u-email">{{useremail}}</div>
                </div>
                <div class="badge-total">
                    {{totalcanjes}} {{str_redemptions}}
                </div>
                <i class="fa fa-chevron-down text-muted" id="icon-{{userid}}"></i>
            </div>
            
            <div class="card-body-logs" id="logs-{{userid}}">
                <div class="card-body-logs-inner">
                <table class="table-logs">
                    <thead>
                        <tr>
                            <th>{{str_activity}}</th>
                            <th>{{str_colcategory}}</th>
                            <th>{{str_type}}</th>
                            <th class="text-center">{{str_cost}}</th>
                            <th class="text-right">{{str_date}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#logs}}
                        <tr>
                            <td class="font-weight-bold" style="font-size: 0.9rem; color: #444;">
                                {{{activityhtml}}}
                            </td>
                            <td>
                                <span style="background: #f0f0f0; color: #555; padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: bold; white-space: nowrap;">
                                    {{categoriatexto}}
                                </span>
                            </td>
                            <td>
                                <span class="badge-tipo bg-{{tipostr}}">
                                    {{labeltipo}}
                                </span>
                            </td>
                            <td class="text-center font-weight-bold text-primary">
                                {{amount}} XP
                            </td>
                            <td class="text-right small text-muted">
                                {{date}}
                            </td>
                        </tr>
                        {{/logs}}
                    </tbody>
                </table>
                </div>
            </div>
        </div>
        {{/users}}
    {{/has_users}}
    {{^has_users}}
        <div class="text-center py-5 text-muted">
            {{str_nopurchases}}
        </div>
    {{/has_users}}
</div>
