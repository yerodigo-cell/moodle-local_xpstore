{{!
    @template local_xpstore/widget_history

    XP Store history widget.

    Context variables required for this template:
    * historyurl - The URL to the history page
    * cpstore - Primary color
    * cbstore - Secondary color
    * str_history - Localized string for 'history'

    Example context (json):
    {
        "historyurl": "http://localhost/moodle/local/xpstore/history.php?id=2",
        "cpstore": "#0056D2",
        "cbstore": "#00C9A7",
        "str_history": "Purchase History"
    }
}}
<div class="local_xpstore-container local_xpstore-embedded-container history-widget" style="--cp: {{cpstore}}; --cb: {{cbstore}}; --gradient: linear-gradient(135deg, var(--cp) 0%, var(--cb) 100%);">
    <a href="{{historyurl}}" target="_top" class="btn-history-widget">
        <i class="fa fa-history"></i>
        {{str_history}}
    </a>
</div>
