{{!
    @template local_xpstore/store_catalog

    Example context (json):
    {
        "url": "https://moodle.org",
        "actionurl": "https://moodle.org",
        "cpstore": "#0056D2",
        "cbstore": "#00C9A7",
        "cistore": "#ff9800",
        "ccstore": "#ffffff",
        "cpactual": "#0056D2",
        "cbactual": "#00C9A7",
        "ciactual": "#ff9800",
        "ccactual": "#ffffff",
        "showbackbutton": true,
        "isteacher": false,
        "saldo": 100,
        "str_configtitle": "Configuration",
        "storecategories": [],
        "str_choosetype": "Choose type",
        "str_chooseactivity": "Choose activity",
        "str_widget_panel_title": "Widgets",
        "str_widget_panel_desc": "Desc",
        "str_colorconfig": "Color",
        "str_primarycolor": "Primary",
        "str_secondarycolor": "Secondary",
        "str_iconcolor": "Icon",
        "str_color_cat_icon": "Cat",
        "str_resetcolors": "Reset",
        "str_savecolors": "Save",
        "str_confirmresetcolors": "Confirm",
        "type_options": [{"value": "1", "label": "dummy"}],
        "activity_options": [{"id": 1, "name": "dummy"}],
        "category_icon_options": [{"catname": "d", "cathash": "h", "currenticon": "star", "icons": [{"value": "star", "label": "Star"}]}],
        "category_iframe_options": [{"iframecat": "a", "currenticon": "star", "catname": "Cat"}]
    }
}}
<div class="local_xpstore-container local_xpstore-full-container tienda-wrapper" style="--cp: {{cpstore}}; --cb: {{cbstore}}; --ci: {{cistore}}; --cc: {{ccstore}}; --gradient: linear-gradient(135deg, var(--cp) 0%, var(--cb) 100%);">
    
    <div class="wallet-header">
        {{#isteacher}}
            <div class="admin-controls">
                <a href="{{reporturl}}" class="admin-btn" style="background: var(--cb) !important; color: white !important;">
                    <i class="fa fa-list-alt"></i> {{str_audit}}
                </a>
                <a href="{{configurl}}" class="admin-btn">
                    <i class="fa fa-cog"></i> {{str_configure}}
                </a>
            </div>
        {{/isteacher}}
        
        <h6 class="text-uppercase small mb-1" style="letter-spacing: 1px; opacity: 0.9;">
            {{str_saldo}}
        </h6>
        <div class="xp-balance">{{saldo}} XP</div>
        <div class="mt-3">
            <a href="{{historyurl}}" class="btn btn-outline-light rounded-pill px-3 py-1" style="font-size: 0.85rem;">
                <i class="fa fa-history"></i> {{str_history}}
            </a>
        </div>
    </div>

    {{#status_success}}
        {{#is_grade_success}}
            <div class="alert alert-success text-center mb-3" style="border-radius: 15px; border: none; background: #d4edda; color: #155724; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                <div style="font-size: 2rem; margin-bottom: 10px; color: #28a745;">
                    <i class="fa fa-star"></i>
                </div>
                <h5 class="font-weight-bold mb-3">{{str_exito}}</h5>
                <a href="{{gradebookurl}}" class="btn btn-success rounded-pill px-4 py-2" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); border: none; font-size: 1rem; font-weight: bold; box-shadow: 0 4px 10px rgba(40,167,69,0.3);">
                    <i class="fa fa-bar-chart mr-2"></i> {{str_gotogradebook}}
                </a>
            </div>
        {{/is_grade_success}}
    {{/status_success}}

    {{#status_limit}}
        <div class="alert alert-warning text-center mb-3" style="border-radius: 10px; padding: 15px; font-weight: bold;">
            {{str_limitreached}}
        </div>
    {{/status_limit}}

    {{#isempty}}
        <div class="alert alert-info text-center" style="border-radius: 15px; border: none; background: #e9ecef; color: #495057; padding: 25px;">
            <i class="fa fa-shopping-basket fa-2x mb-2" style="color: #adb5bd;"></i>
            <h5 class="mb-1">{{str_storeempty_title}}</h5>
            <p class="small m-0">{{str_storeempty_desc}}</p>
        </div>
    {{/isempty}}

    {{^isempty}}
        {{#categoriastienda}}
            <h4 class="mt-4 mb-4 font-weight-bold" style="color: #333; font-size: 1.8rem; text-align: center; letter-spacing: -0.5px;">
                <i class="fa fa-{{caticon}} mr-2" style="color: var(--cc);"></i> {{nombreseccion}}
            </h4>
            
            <div class="product-grid" style="margin-bottom: 50px;">
                {{#productos}}
                    <div class="p-card">
                        <div>
                            <div style="font-size: 20px; color: var(--ci); margin-bottom: 10px;">
                                <i class="fa fa-{{icon}}"></i>
                            </div>
                            
                            {{#is_bonus}}
                                <div class="grade-badge">
                                    +{{boost}} {{str_points}}
                                </div>
                            {{/is_bonus}}
                            
                            {{#is_special}}
                                <div class="grade-badge" style="background: var(--cb); color: white;">
                                    {{str_specialcontent}}
                                </div>
                            {{/is_special}}
                            
                            <div class="font-weight-bold" style="font-size: 1rem; line-height: 1.2; margin-bottom: 4px;">
                                {{displayname}}
                            </div>
                            <div class="text-muted small mb-2" style="font-size: 0.75rem;">
                                {{nreal}}
                            </div>
                        </div>
                        
                        <div>
                            <div class="h5 font-weight-bold text-primary m-0">{{costo}} XP</div>
                            
                            {{#has_limit}}
                                <div class="w-limit">
                                    {{str_redemptions_count}} {{comprasactuales}} / {{limite}}
                                </div>
                            {{/has_limit}}
                            {{^has_limit}}
                                <div style="margin-bottom: 8px;"></div>
                            {{/has_limit}}
                            
                            {{#bought_this}}
                                {{#gotogradebook}}
                                    <a href="{{gradebookurl}}" class="btn-go-activity">
                                        <i class="fa fa-bar-chart mr-1"></i> {{str_gotogradebook}}
                                    </a>
                                {{/gotogradebook}}
                                {{^gotogradebook}}
                                    <a href="{{cmurl}}" class="btn-go-activity">
                                        <i class="fa fa-external-link mr-1"></i> {{str_gotoactivity}}
                                    </a>
                                {{/gotogradebook}}
                            {{/bought_this}}
                            {{^bought_this}}
                                <form method="POST" action="{{actionurl}}">
                                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                                    <input type="hidden" name="action" value="comprar">
                                    <input type="hidden" name="cmid" value="{{cid}}">
                                    <input type="hidden" name="tipo" value="{{tipo}}">
                                    <input type="hidden" name="costo" value="{{costo}}">
                                    
                                    {{#limitealcanzado}}
                                        <button type="button" class="btn-buy" disabled style="background: #e0e0e0; color: #888;">
                                            {{str_soldout}}
                                        </button>
                                    {{/limitealcanzado}}
                                    {{^limitealcanzado}}
                                        <button type="submit" class="btn-buy" {{#disabled}}disabled{{/disabled}}>
                                            {{btntext}}
                                        </button>
                                    {{/limitealcanzado}}
                                </form>
                            {{/bought_this}}
                        </div>
                    </div>
                {{/productos}}
            </div>
        {{/categoriastienda}}
    {{/isempty}}
</div>
