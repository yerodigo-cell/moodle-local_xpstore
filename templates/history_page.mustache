{{!
    @template local_xpstore/history_page

    Example context (json):
    {
        "url": "https://moodle.org",
        "actionurl": "https://moodle.org",
        "cpstore": "#0056D2",
        "cbstore": "#00C9A7",
        "cistore": "#ff9800",
        "ccstore": "#ffffff",
        "cpactual": "#0056D2",
        "cbactual": "#00C9A7",
        "ciactual": "#ff9800",
        "ccactual": "#ffffff",
        "showbackbutton": true,
        "isteacher": false,
        "saldo": 100,
        "str_configtitle": "Configuration",
        "storecategories": [],
        "str_choosetype": "Choose type",
        "str_chooseactivity": "Choose activity",
        "str_widget_panel_title": "Widgets",
        "str_widget_panel_desc": "Desc",
        "str_colorconfig": "Color",
        "str_primarycolor": "Primary",
        "str_secondarycolor": "Secondary",
        "str_iconcolor": "Icon",
        "str_color_cat_icon": "Cat",
        "str_resetcolors": "Reset",
        "str_savecolors": "Save",
        "str_confirmresetcolors": "Confirm",
        "type_options": [{"value": "1", "label": "dummy"}],
        "activity_options": [{"id": 1, "name": "dummy"}],
        "category_icon_options": [{"catname": "d", "cathash": "h", "currenticon": "star", "icons": [{"value": "star", "label": "Star"}]}],
        "category_iframe_options": [{"iframecat": "a", "currenticon": "star", "catname": "Cat"}]
    }
}}
<div class="local_xpstore-container history-wrapper">
    <div class="header-container">
        <div class="header-title">
            <h2>
                <i class="fa fa-history mr-2" style="color: #0056D2;"></i> 
                {{str_history}}
            </h2>
        </div>
        
        {{#showbackbutton}}
            <a href="{{storeurl}}" class="btn-tienda">
                <i class="fa fa-arrow-left"></i> {{str_tiendaxp}}
            </a>
        {{/showbackbutton}}
    </div>

    <div class="table-responsive-wrapper">
        <table class="table-history">
            <thead>
                <tr>
                    <th>{{str_activity}}</th>
                    <th>{{str_type}}</th>
                    <th class="text-center">{{str_cost}}</th>
                    <th>{{str_date}}</th>
                    <th class="text-right">{{str_action}}</th>
                </tr>
            </thead>
            <tbody>
                {{#has_logs}}
                    {{#logs}}
                    <tr>
                        <td class="td-first font-weight-bold" style="color: #444; white-space: nowrap;">
                            {{activityname}}
                            {{#customlabel}}
                            <div style="font-size: 0.75rem; color: #777; margin-top: 4px; font-weight: normal; white-space: normal;">
                                <i class="fa fa-tag text-muted" style="margin-right: 3px;"></i>{{customlabel}}
                            </div>
                            {{/customlabel}}
                        </td>
                        <td>
                            <span class="badge-tipo bg-{{tipostr}}">
                                {{labeltipo}}
                            </span>
                        </td>
                        <td class="text-center font-weight-bold text-primary" style="white-space: nowrap;">
                            {{amount}} XP
                        </td>
                        <td class="small text-muted" style="white-space: nowrap;">
                            {{date}}
                        </td>
                        <td class="td-last text-right">
                            {{#is_grade}}
                                <a href="{{gradeurl}}" class="btn-action-history btn-grade">
                                    <i class="fa fa-bar-chart"></i> {{str_gotogradebook}}
                                </a>
                            {{/is_grade}}
                            {{^is_grade}}
                                <a href="{{cmurl}}" class="btn-action-history btn-activity">
                                    <i class="fa fa-external-link"></i> {{str_gotoactivity}}
                                </a>
                            {{/is_grade}}
                        </td>
                    </tr>
                    {{/logs}}
                {{/has_logs}}
                {{^has_logs}}
                    <tr><td colspan="5" class="text-center py-5 text-muted" style="border-radius: 12px;">
                         {{str_nopurchases}}
                    </td></tr>
                {{/has_logs}}
            </tbody>
        </table>
    </div>
</div>
