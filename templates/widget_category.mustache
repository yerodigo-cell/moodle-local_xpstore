{{!
    @template local_xpstore/widget_category

    Example context (json):
    {
        "url": "https://moodle.org",
        "actionurl": "https://moodle.org",
        "cpstore": "#0056D2",
        "cbstore": "#00C9A7",
        "cistore": "#ff9800",
        "ccstore": "#ffffff",
        "cpactual": "#0056D2",
        "cbactual": "#00C9A7",
        "ciactual": "#ff9800",
        "ccactual": "#ffffff",
        "showbackbutton": true,
        "isteacher": false,
        "saldo": 100,
        "str_configtitle": "Configuration",
        "storecategories": [],
        "str_choosetype": "Choose type",
        "str_chooseactivity": "Choose activity",
        "str_widget_panel_title": "Widgets",
        "str_widget_panel_desc": "Desc",
        "str_colorconfig": "Color",
        "str_primarycolor": "Primary",
        "str_secondarycolor": "Secondary",
        "str_iconcolor": "Icon",
        "str_color_cat_icon": "Cat",
        "str_resetcolors": "Reset",
        "str_savecolors": "Save",
        "str_confirmresetcolors": "Confirm",
        "type_options": [{"value": "1", "label": "dummy"}],
        "activity_options": [{"id": 1, "name": "dummy"}],
        "category_icon_options": [{"catname": "d", "cathash": "h", "currenticon": "star", "icons": [{"value": "star", "label": "Star"}]}],
        "category_iframe_options": [{"iframecat": "a", "currenticon": "star", "catname": "Cat"}]
    }
}}
<div class="local_xpstore-container local_xpstore-embedded-container tienda-wrapper" style="--cp: {{cpstore}}; --cb: {{cbstore}}; --ci: {{cistore}}; --cc: {{ccstore}}; --gradient: linear-gradient(135deg, var(--cp) 0%, var(--cb) 100%);">
    
    <div class="wallet-header">
        <div class="text-uppercase small mb-1" style="letter-spacing: 1px; font-weight: bold; opacity: 0.9;">
            {{str_saldo}}
        </div>
        <div class="xp-balance"><span class="xp-balance-value">{{saldo}}</span> XP</div>
        <a href="{{historyurl}}" target="_top" class="btn-history">
            {{str_history}}
        </a>
    </div>


    
    {{#status_error}}
        <div class="alert alert-danger text-center mb-3" style="border-radius: 10px; padding: 10px;">
            {{str_insuficiente}}
        </div>
    {{/status_error}}
    
    {{#status_limit}}
        <div class="alert alert-warning text-center mb-3" style="border-radius: 10px; padding: 10px; font-weight: bold;">
            {{str_limitreached}}
        </div>
    {{/status_limit}}

    {{#isempty}}
        <div class="alert alert-info text-center" style="border-radius: 10px; padding: 15px; font-size: 0.9rem;">
            {{str_widgeterror}}
        </div>
    {{/isempty}}

    {{^isempty}}
        {{#categoriastienda}}
            <h4 class="mt-4 mb-4 font-weight-bold" style="color: #333; font-size: 1.6rem; text-align: center; letter-spacing: -0.5px;">
                <i class="fa fa-{{caticon}} mr-2" style="color: var(--cc);"></i> {{nombreseccion}}
            </h4>
            
            <div class="product-grid" style="margin-bottom: 50px;">
                {{#productos}}
                    <div class="p-card">
                        <div class="glass-shine"></div>
                        <div>
                            <div style="font-size: 20px; color: var(--ci); margin-bottom: 8px;">
                                <i class="fa fa-{{icon}}"></i>
                            </div>
                            
                            {{#is_bonus}}
                                <div class="grade-badge">
                                    +{{boost}} {{str_points}}
                                </div>
                            {{/is_bonus}}
                            
                            {{#is_special}}
                                <div class="grade-badge" style="background: var(--cb); color: white;">
                                    {{str_specialcontent}}
                                </div>
                            {{/is_special}}
                            
                            <div class="font-weight-bold" style="font-size: 0.95rem; line-height: 1.2; margin-bottom: 4px;">
                                {{displayname}}
                            </div>
                            <div class="text-muted small mb-2" style="font-size: 0.75rem;">
                                {{nreal}}
                            </div>
                        </div>
                        
                        <div>
                            <div class="font-weight-bold text-primary m-0" style="font-size: 1.1rem;">
                                {{costo}} XP
                            </div>
                            
                            {{#has_limit}}
                                <div class="w-limit">
                                    {{str_redemptions_count}} {{comprasactuales}} / {{limite}}
                                </div>
                            {{/has_limit}}
                            {{^has_limit}}
                                <div style="margin-bottom: 8px;"></div>
                            {{/has_limit}}
                            
                            {{#bought_this}}
                                {{#gotogradebook}}
                                    <a href="{{gradebookurl}}" target="_top" class="btn-go-activity">
                                        {{str_gotogradebook}}
                                    </a>
                                {{/gotogradebook}}
                                {{^gotogradebook}}
                                    <a href="{{cmurl}}" target="_top" class="btn-go-activity">
                                        {{str_gotoactivity}}
                                    </a>
                                {{/gotogradebook}}
                            {{/bought_this}}
                            {{^bought_this}}
                                <form method="POST" action="{{actionurl}}" onsubmit="var b=this.querySelector('button[type=submit]'); if(b){b.disabled=true; b.classList.add('btn-loading'); b.innerHTML='<span class=\'ai-sparkles-group\'><i class=\'ai-sparkle s1\'></i><i class=\'ai-sparkle s2\'></i><i class=\'ai-sparkle s3\'></i><i class=\'ai-sparkle s4\'></i></span>';}">
                                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                                    <input type="hidden" name="action" value="comprar">
                                    <input type="hidden" name="cmid" value="{{cid}}">
                                    <input type="hidden" name="tipo" value="{{tipo}}">
                                    <input type="hidden" name="costo" value="{{costo}}">
                                    
                                    {{#limitealcanzado}}
                                        <button type="button" class="btn-buy btn-buy-disabled" onclick="var c = this.closest('.p-card') || this.closest('.widget-card'); c.classList.remove('shake-error'); void c.offsetWidth; c.classList.add('shake-error');">
                                            {{str_soldout}}
                                        </button>
                                    {{/limitealcanzado}}
                                    {{^limitealcanzado}}
                                        <button type="{{#disabled}}button{{/disabled}}{{^disabled}}submit{{/disabled}}" class="btn-buy {{#disabled}}btn-buy-disabled{{/disabled}}" {{#disabled}}onclick="var c = this.closest('.p-card') || this.closest('.widget-card'); c.classList.remove('shake-error'); void c.offsetWidth; c.classList.add('shake-error');"{{/disabled}}>
                                            {{btntext}}
                                        </button>
                                    {{/limitealcanzado}}
                                </form>
                            {{/bought_this}}
                        </div>
                    </div>
                {{/productos}}
            </div>
        {{/categoriastienda}}
    {{/isempty}}
</div>
{{#status_success}}
{{#js}}
require(['core/modal_factory'], function(ModalFactory) {
    function fireConfetti() {
        var colors = ['#0056D2', '#00C9A7', '#ff9800', '#ff0000', '#ffd700', '#9c27b0'];
        for (var i = 0; i < 80; i++) {
            var confetti = document.createElement('div');
            confetti.style.position = 'fixed';
            confetti.style.width = (Math.random() * 8 + 6) + 'px';
            confetti.style.height = (Math.random() * 8 + 6) + 'px';
            confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            confetti.style.top = '50%';
            confetti.style.left = '50%';
            confetti.style.borderRadius = (Math.random() > 0.5 ? '50%' : '0');
            confetti.style.zIndex = '10001';
            confetti.style.pointerEvents = 'none';
            document.body.appendChild(confetti);

            var angle = Math.random() * Math.PI * 2;
            var velocity = 80 + Math.random() * 250;
            var tx = Math.cos(angle) * velocity;
            var ty = Math.sin(angle) * velocity - 100;

            confetti.animate([
                { transform: 'translate(-50%, -50%) scale(0) rotate(0deg)', opacity: 1 },
                { transform: 'translate(calc(-50% + ' + tx + 'px), calc(-50% + ' + ty + 'px)) scale(1.5) rotate(' + (Math.random() * 720) + 'deg)', opacity: 1, offset: 0.7 },
                { transform: 'translate(calc(-50% + ' + tx + 'px), calc(-50% + ' + ty + 150 + 'px)) scale(0) rotate(' + (Math.random() * 1080) + 'deg)', opacity: 0 }
            ], {
                duration: 1500 + Math.random() * 1000,
                easing: 'cubic-bezier(.25,.1,.25,1)',
                fill: 'forwards'
            }).onfinish = function() {
                this.effect.target.remove();
            };
        }
    }
    function playSuccessSound() {
        try {
            var AudioContext = window.AudioContext || window.webkitAudioContext;
            if (!AudioContext) return;
            var ctx = new AudioContext();
            
            function playNote(freq, delay) {
                var osc = ctx.createOscillator();
                var gain = ctx.createGain();
                osc.type = 'sine';
                osc.frequency.setValueAtTime(freq, ctx.currentTime + delay);
                
                gain.gain.setValueAtTime(0, ctx.currentTime + delay);
                gain.gain.linearRampToValueAtTime(0.1, ctx.currentTime + delay + 0.05);
                gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + delay + 1.0);
                
                osc.connect(gain);
                gain.connect(ctx.destination);
                
                osc.start(ctx.currentTime + delay);
                osc.stop(ctx.currentTime + delay + 1.1);
            }

            playNote(523.25, 0.0);
            playNote(659.25, 0.08);
            playNote(783.99, 0.16);
            playNote(1046.50, 0.24);
            playNote(1318.51, 0.32);
        } catch(e) {}
    }
    
        setTimeout(fireConfetti, 50);
        setTimeout(playSuccessSound, 50);
        
        ModalFactory.create({
            type: ModalFactory.types.DEFAULT,
            title: '{{str_congratulations}}',
            body: '<div class="epic-celebration-body"><div class="epic-icon-wrapper"><div class="epic-icon-container"><i class="fa fa-{{success_icon}}"></i><div class="epic-sparkle"></div></div></div><div class="epic-title">{{str_congratulations}}</div><div class="epic-desc">{{{str_success_unlock}}}</div><a href="{{redirecturl}}" target="_top" class="btn-claim-reward">{{str_goto_dest}}</a></div>',
        }).then(function(modal) {
            modal.getRoot().addClass('epic-celebration-modal');
            var rootNode = modal.getRoot()[0];
            if (rootNode && rootNode.parentElement) {
                rootNode.parentElement.style.backgroundColor = 'rgba(0,0,0,0.8)';
                rootNode.parentElement.style.backdropFilter = 'blur(10px)';
            }
            modal.show();
        }).catch(function(e) {
            console.error("ModalFactory error:", e);
        });
    });
{{/js}}
{{/status_success}}

<script>
(function() {
    function autoResizeXpStore() {
        try {
            if (window.frameElement) {
                var container = document.querySelector('.local_xpstore-embedded-container');
                if (container) {
                    var newH = container.scrollHeight;
                    if (newH > 200) {
                        window.frameElement.style.height = (newH + 30) + 'px';
                    }
                }
            }
        } catch(e) {}
    }
    
    var count = 0;
    var interval = setInterval(function() {
        autoResizeXpStore();
        count++;
        if (count > 10) clearInterval(interval);
    }, 500);
    
    window.addEventListener('load', autoResizeXpStore);
    window.addEventListener('resize', autoResizeXpStore);
})();

(function() {
    try {
        if (window.BroadcastChannel) {
            var bc = new BroadcastChannel('xpstore_balance_sync');
            bc.onmessage = function(ev) {
                if (ev.data && ev.data.type === 'update_balance' && ev.data.newBalance !== undefined) {
                    var els = document.querySelectorAll('.xp-balance-value');
                    els.forEach(function(el) { el.textContent = ev.data.newBalance; });
                }
            };
            {{#status_success}}
            setTimeout(function() {
                bc.postMessage({ type: 'update_balance', newBalance: '{{saldo}}' });
            }, 100);
            {{/status_success}}
        }
    } catch(e) {}
})();
</script>
